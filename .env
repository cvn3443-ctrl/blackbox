# Mo.dark – BlackBox Environment Variables
# هذا الملف يحتوي على المتغيرات السرية للمشروع

# كلمة مرور لوحة التحكم (يمكنك تغييرها لاحقاً)
ADMIN_PASSWORD=BlackBox@2026#Secure

# مفاتيح Binance API (سيتم إضافتها عند تفعيل الإيداع التلقائي)
# BINANCE_API_KEY=your_api_key_here
# BINANCE_SECRET_KEY=your_secret_key_here

# عنوان محفظة Binance الرئيسية (للاستقبال)
# MAIN_WALLET_ADDRESS=your_binance_wallet_address

# إعدادات إضافية
PORT=3000
NODE_ENV=production
